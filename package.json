{
	"name": "autai",
	"version": "0.0.0",
	"private": true,
	"description": "Automatic AI Agent Driven Browser DOM testbed",
	"license": "MIT",
	"author": "Yuwei Zhu <zyw@tutamail.com>",
	"type": "module",
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build && electron-builder",
		"preview": "electron-vite preview",
		"start": "electron-vite preview --skipBuild",
		"tsc:node": "tsc --noEmit -p tsconfig.node.json --composite false",
		"tsc:web": "tsc --noEmit -p tsconfig.web.json --composite false",
		"tsc": "pnpm tsc:node && pnpm tsc:web",
		"test": "vitest run",
		"lint": "eslint .",
		"format": "prettier --write src/",
		"postinstall": "node scripts/postinstall.js"
	},
	"prettier": {
		"experimentalTernaries": true,
		"tabWidth": 2,
		"useTabs": false
	},
	"dependencies": {
		"electron-updater": "^6.7.3"
	},
	"devDependencies": {
		"@electron-toolkit/preload": "^3.0.2",
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@electron-toolkit/utils": "^4.0.0",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/vite": "^4.1.18",
		"@types/express": "^5.0.6",
		"@types/node": "^25.2.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"clsx": "^2.1.1",
		"devtools-protocol": "^0.0.1585077",
		"electron": "^40.4.1",
		"electron-builder": "^26.7.0",
		"electron-log": "^5.4.3",
		"electron-vite": "^5.0.0",
		"eslint": "^10.0.0",
		"express": "^5.2.1",
		"p-queue": "^9.1.0",
		"postcss": "^8.5.6",
		"prettier": "^3.8.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.4.1",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"debug": {
		"env": {
			"VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
		}
	}
}
